<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Flower Group: Centered at 54,54 -->
    <group
        android:translateX="54"
        android:translateY="54"
        android:scaleX="0.5"
        android:scaleY="0.5">
        
        <!-- A more sophisticated petal path that tapers at both ends -->
        <!-- M 0,0  (center)
             C 10,-5 15,-20 0,-40 (outer curve)
             C -15,-20 -10,-5 0,0 (return curve) -->
        <group android:rotation="0">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M0,0 C12,-10 18,-30 0,-50 C-18,-30 -12,-10 0,0 Z" />
        </group>
        <group android:rotation="45">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M0,0 C12,-10 18,-30 0,-50 C-18,-30 -12,-10 0,0 Z" />
        </group>
        <group android:rotation="90">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M0,0 C12,-10 18,-30 0,-50 C-18,-30 -12,-10 0,0 Z" />
        </group>
        <group android:rotation="135">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M0,0 C12,-10 18,-30 0,-50 C-18,-30 -12,-10 0,0 Z" />
        </group>
        <group android:rotation="180">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M0,0 C12,-10 18,-30 0,-50 C-18,-30 -12,-10 0,0 Z" />
        </group>
        <group android:rotation="225">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M0,0 C12,-10 18,-30 0,-50 C-18,-30 -12,-10 0,0 Z" />
        </group>
        <group android:rotation="270">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M0,0 C12,-10 18,-30 0,-50 C-18,-30 -12,-10 0,0 Z" />
        </group>
        <group android:rotation="315">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M0,0 C12,-10 18,-30 0,-50 C-18,-30 -12,-10 0,0 Z" />
        </group>

        <!-- Central Circle with a small hole (matching the layered look) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,0m-12,0a12,12 0,1 1,24 0a12,12 0,1 1,-24 0" />
        
        <!-- Subtle hole in center -->
        <path
            android:fillColor="#FF8A65"
            android:pathData="M0,0m-4,0a4,4 0,1 1,8 0a4,4 0,1 1,-8 0" />
    </group>
</vector>
