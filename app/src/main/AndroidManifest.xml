<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Storage permissions for reading images -->
    <!-- TODO: Use Accompanist Permissions to request at runtime -->
    <!-- TODO: Show rationale dialog if permission was previously denied -->
    <!-- TODO: Handle permanently denied state with Settings redirect -->

    <!-- Required for API 33+ (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <!-- Required for API < 33 -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- Allows bypassing per-file permission prompts for delete/trash on API 31+ -->
    <uses-permission android:name="android.permission.MANAGE_MEDIA" />

    <!-- Internet permission for loading placeholder images from picsum.photos -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".SimpleGalleryApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimpleGallery"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SimpleGallery">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- TODO: Handle deep links for shared image URIs -->
            <!-- Example deep link handler:
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            -->
        </activity>
    </application>

</manifest>
